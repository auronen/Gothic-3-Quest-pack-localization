{
    "SVM_Zuben_Aargh_00": "Ааах!",
    "SVM_Zuben_Aargh_01": "Ааах!",
    "SVM_Zuben_Aargh_02": "Ааах!",
    "SVM_Zuben_AdanosTeacher_00": "Лід і холод - віднині твоїм мечем стануть проти всіх, хто насмілиться стати на заваді волі Аданоса!",
    "SVM_Zuben_AdanosTeacher_01": "Аданос дарує тобі свою силу, щоб ти допоміг скеровувати долю цього світу.",
    "SVM_Zuben_AdanosTeacher_02": "Сила означає відповідальність. Аданос не дарує її легковажно.",
    "SVM_Zuben_Alarm": "Тривога!",
    "SVM_Zuben_Alchemist": "Якісні інгредієнти... ось до чого це зводиться..",
    "SVM_Zuben_AndNowGetOutOfHere": "А тепер забирайся звідси!",
    "SVM_Zuben_AngryRefuse": "Через тебе у мене й так вистачає неприємностей!",
    "SVM_Zuben_ArenaAttack": "Ти мені не рівня!",
    "SVM_Zuben_Awake": "(широко позіхає)",
    "SVM_Zuben_Barbecue": "Хрусткі зовні та соковиті всередині!",
    "SVM_Zuben_BeliarTeacher_00": "Беліар надає тобі силу, щоб ти знищував його ворогів!",
    "SVM_Zuben_BeliarTeacher_01": "Відтепер істоти Беліара будуть битися поруч із тобою.",
    "SVM_Zuben_BeliarTeacher_02": "Беліар не ділиться своєю силою просто так. Пам’ятай про це.",
    "SVM_Zuben_BetterGoNow": "Краще йди звідси!",
    "SVM_Zuben_BetterNotTalk": "",
    "SVM_Zuben_BigMonsterKilled": "",
    "SVM_Zuben_Campfire": "",
    "SVM_Zuben_Carry": "",
    "SVM_Zuben_CertainlyBusy": "Напевно, у тебе ще багато справ!",
    "SVM_Zuben_Cheer_00": "Саме так!",
    "SVM_Zuben_Cheer_01": "Вріж йому!",
    "SVM_Zuben_Cheer_02": "Та-а-ак!",
    "SVM_Zuben_Cook": "Це буде смачно!",
    "SVM_Zuben_Dead": "Ааааааах!",
    "SVM_Zuben_DestinationNear": "Це має бути десь тут!",
    "SVM_Zuben_DieBigMonster": "Згинь, потворо!",
    "SVM_Zuben_DieEnemy_00": "Зараз ти помреш!",
    "SVM_Zuben_DieEnemy_01": "Пробила твоя остання година!",
    "SVM_Zuben_DieEnemy_02": "Я відправлю тебе до Беліара!",
    "SVM_Zuben_DieMonster_00": "Ще одна з цих жалюгідних істот!",
    "SVM_Zuben_DieMonster_01": "Беліар чекає на тебе!",
    "SVM_Zuben_DieMonster_02": "Я вб’ю цю потвору!",
    "SVM_Zuben_DirtyThief": "Ти, мерзенний злодюжко!",
